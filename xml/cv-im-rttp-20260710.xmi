						<upperValue xmi:type="uml:LiteralString" xmi:id="U3fdafd19-62bd-44ad-8187-a5554e84d32d" xmi:uuid="3fdafd19-62bd-44ad-8187-a5554e84d32d" value="*"/>
						<ownedComment xmi:type="uml:Comment" xmi:id="U5352c7b8-2724-403b-bb84-a52036cb5e84" xmi:uuid="5352c7b8-2724-403b-bb84-a52036cb5e84" body="Verwijzing naar een begrip, vanuit een modelelement, waarmee wordt aangegeven op welk begrip, of begrippen, het informatiemodel element is gebaseerd. De verwijzing heeft de vorm van een term of een URI.">
							<annotatedElement xmi:idref="U087219e2-4b96-432e-a0e0-6773597a78f3"/>
						</ownedComment>
					</ownedAttribute>
					<ownedAttribute xmi:type="uml:Property" xmi:id="Uc1fede7e-1559-4a18-b89b-e962751f3cc4" xmi:uuid="c1fede7e-1559-4a18-b89b-e962751f3cc4" name="Herkomst" visibility="public">
