								<annotatedElement xmi:idref="U54d30b9f-ba37-4f3a-8427-6f7b618495e3"/>
							</ownedComment>
						</ownedAttribute>
						<ownedAttribute xmi:type="uml:Property" xmi:id="Uc46776c6-59d3-4671-af9e-6cbcf89c5c86" xmi:uuid="c46776c6-59d3-4671-af9e-6cbcf89c5c86" name="Minimumwaarde exclusief" visibility="public">
