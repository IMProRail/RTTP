						<ownedAttribute xmi:type="uml:Property" xmi:id="Ufac01203-424f-4f32-b0b0-2abcac372997" xmi:uuid="fac01203-424f-4f32-b0b0-2abcac372997" name="checkingBody">
							<xmi:Extension extender="UModel">
								<attributeExtension DocComment="Ua6c5e391-b317-4e3d-885f-534cd88d1617"/>
							</xmi:Extension>
							<ownedComment xmi:type="uml:Comment" xmi:id="Ua6c5e391-b317-4e3d-885f-534cd88d1617" xmi:uuid="a6c5e391-b317-4e3d-885f-534cd88d1617" body="Identification of the body which performed the RID check"/>
						</ownedAttribute>
						<ownedAttribute xmi:type="uml:Property" xmi:id="U70bb50f8-91c2-471a-bad1-33e9753bf47c" xmi:uuid="70bb50f8-91c2-471a-bad1-33e9753bf47c" name="checkingType">
							<xmi:Extension extender="UModel">
								<attributeExtension DocComment="Ua5b3d043-614d-4aa8-ad4c-20752f6c760e"/>
							</xmi:Extension>
							<ownedComment xmi:type="uml:Comment" xmi:id="Ua5b3d043-614d-4aa8-ad4c-20752f6c760e" xmi:uuid="a5b3d043-614d-4aa8-ad4c-20752f6c760e" body="Following types of checks are authorised (RID 1.4.3):&#10;&#10;Carrier:&#10;01 Prescribed documentation attached to transport docuemnt&#10;02 Defects, leackages, cracks, missing equipment on wagons or equipment&#10;&#10;Loader:&#10;11 Damage of packing&#10;12 Compliance with prohibition on mixed loading&#10;13 Uncleaned empty package&#10;&#10;Filler:&#10;21 Date of next inspection of wagons&#10;22 DG is filled only into authorized tanks&#10;23 Permissible level of filling&#10;24 Plackards, plates from RID chapter 5.3 are visible on wagon&#10;25 Correct Closure of wagons / tanks&#10;26 Leackage on wagons / tanks&#10;&#10;Unloader:&#10;31 Damage of packages or of tanks&#10;32 Required DG documentation available&#10;33 Cleaning, degasing, decontamination of wagons from residues&#10;34 Plackards, plates from RID chapter 5.3 are removed from wagon&#10;"/>
						</ownedAttribute>
						<ownedAttribute xmi:type="uml:Property" xmi:id="U79294f5a-830c-429f-9347-75e29b95e712" xmi:uuid="79294f5a-830c-429f-9347-75e29b95e712" name="checkingDateTime">
							<xmi:Extension extender="UModel">
								<attributeExtension DocComment="U870c9496-13ea-4e6a-8b90-9410b4751e53"/>
							</xmi:Extension>
							<ownedComment xmi:type="uml:Comment" xmi:id="U870c9496-13ea-4e6a-8b90-9410b4751e53" xmi:uuid="870c9496-13ea-4e6a-8b90-9410b4751e53" body="Date and Time when the check was performed"/>
						</ownedAttribute>
						<ownedAttribute xmi:type="uml:Property" xmi:id="Ub2c1f286-f3a8-4210-b156-0daf1866d06c" xmi:uuid="b2c1f286-f3a8-4210-b156-0daf1866d06c" name="checkingLocation">
							<xmi:Extension extender="UModel">
								<attributeExtension DocComment="U4f96256d-217b-4d85-9d11-196a4bff8b8f"/>
							</xmi:Extension>
