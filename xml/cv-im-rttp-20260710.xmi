						</ownedComment>
					</ownedAttribute>
					<ownedAttribute xmi:type="uml:Property" xmi:id="U087219e2-4b96-432e-a0e0-6773597a78f3" xmi:uuid="087219e2-4b96-432e-a0e0-6773597a78f3" name="Begrip" visibility="public">
