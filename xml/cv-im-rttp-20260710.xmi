						<ownedAttribute xmi:type="uml:Property" xmi:id="Ubc368565-91f7-4de5-8985-6bd317433da2" xmi:uuid="bc368565-91f7-4de5-8985-6bd317433da2" name="Maximumwaarde exclusief" visibility="public">
							<xmi:Extension extender="UModel">
								<attributeExtension DocComment="Uc3d656ce-128a-4801-8e34-279c2ef911ed"/>
							</xmi:Extension>
							<ownedComment xmi:type="uml:Comment" xmi:id="Uc3d656ce-128a-4801-8e34-279c2ef911ed" xmi:uuid="c3d656ce-128a-4801-8e34-279c2ef911ed" body="Maximumwaarde exclusief (&lt;) is de bovengrens van het waardebereik voor een attribuutsoort of data element getypeerd met een primitief datatype, exclusief die waarde zelf. De maximumwaarde moet van hetzelfde primitieve datatype zijn als het datatype van het modelelement waar het voor geldt.">
								<annotatedElement xmi:idref="Ubc368565-91f7-4de5-8985-6bd317433da2"/>
							</ownedComment>
						</ownedAttribute>
						<ownedAttribute xmi:type="uml:Property" xmi:id="U54d30b9f-ba37-4f3a-8427-6f7b618495e3" xmi:uuid="54d30b9f-ba37-4f3a-8427-6f7b618495e3" name="Maximumwaarde inclusief" visibility="public">
