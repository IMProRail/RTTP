						</ownedAttribute>
						<ownedAttribute xmi:type="uml:Property" xmi:id="Ub4f51206-d0e8-4e9c-9067-4af1e6173454" xmi:uuid="b4f51206-d0e8-4e9c-9067-4af1e6173454" name="checkingResults">
							<xmi:Extension extender="UModel">
								<attributeExtension DocComment="U232e0531-aeef-4495-9770-57966ad8e3c1"/>
							</xmi:Extension>
