					<memberEnd xmi:idref="U0720a309-ea44-4400-a1a8-478abe2c0318"/>
					<xmi:Extension extender="UModel">
						<attributeExtension DocComment="Ua9b8c8c4-fe74-443f-941c-71eedb60e8b5"/>
						<appliedStereotype xmi:type="uml:StereotypeApplication" xmi:id="U9281aead-1523-4e2b-b6d1-1c264db8ea54" xmi:uuid="9281aead-1523-4e2b-b6d1-1c264db8ea54" visibility="unspecified" classifier="Ua3f23150-c9db-43af-93fd-d6497db74bd2">
							<slot xmi:type="uml:Slot" xmi:id="Ued1aef1a-e809-4eb0-89df-2bb502f8f6c5" xmi:uuid="ed1aef1a-e809-4eb0-89df-2bb502f8f6c5" definingFeature="Uc53a5521-b1c4-4658-b972-2fcf2d8cd178">
								<value xmi:type="uml:LiteralString" xmi:id="U8c03828b-ab63-4e1b-ae8a-237423c6a605" xmi:uuid="8c03828b-ab63-4e1b-ae8a-237423c6a605" value="Een gebeurtenisvolgorde legt de expliciete ordening vast tussen twee gebeurtenissen (bron en doel) die plaatsvinden op dezelfde operationele locatie. Deze volgorde representeert de volgorde van gebruik van infrastructuurcapaciteit en wordt toegepast in situaties waarin deze niet eenduidig uit tijdstippen kan worden afgeleid of expliciet moet worden vastgelegd voor planning en bijsturing. Constraint: bronGebeurtenis en doelGebeurtenis vinden plaats op dezelfde operationele locatie."/>
							</slot>
