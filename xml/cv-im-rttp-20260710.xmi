						<ownedComment xmi:type="uml:Comment" xmi:id="Uc5c7ab01-a37d-4c9c-9244-24e1d1c77491" xmi:uuid="c5c7ab01-a37d-4c9c-9244-24e1d1c77491" body="Indicatie of de materiële historie van het kenmerk van het object te bevragen is.">
							<annotatedElement xmi:idref="U176992e4-8a31-4a11-a215-2da7354ea02c"/>
						</ownedComment>
					</ownedAttribute>
					<ownedAttribute xmi:type="uml:Property" xmi:id="U8b8d13f4-e2fc-4b3d-83e8-795241d2adcf" xmi:uuid="8b8d13f4-e2fc-4b3d-83e8-795241d2adcf" name="Locatie" visibility="public">
						<xmi:Extension extender="UModel">
							<attributeExtension DocComment="U1220aeac-b7da-4208-b48a-b75bf08d3482"/>
						</xmi:Extension>
						<ownedComment xmi:type="uml:Comment" xmi:id="U1220aeac-b7da-4208-b48a-b75bf08d3482" xmi:uuid="1220aeac-b7da-4208-b48a-b75bf08d3482" body="ls het type van het attribuutsoort een waardenlijst is, dan wordt hier de locatie waar deze te vinden is opgegeven.">
							<annotatedElement xmi:idref="U8b8d13f4-e2fc-4b3d-83e8-795241d2adcf"/>
						</ownedComment>
					</ownedAttribute>
					<ownedAttribute xmi:type="uml:Property" xmi:id="Ufd1d1ddb-b979-46d8-b3ee-e0e1894ab61d" xmi:uuid="fd1d1ddb-b979-46d8-b3ee-e0e1894ab61d" name="Maximumwaarde exclusief" visibility="public">
						<xmi:Extension extender="UModel">
							<attributeExtension DocComment="Uc87de3ff-116b-4f7f-8749-c10bf42344f2"/>
						</xmi:Extension>
						<ownedComment xmi:type="uml:Comment" xmi:id="Uc87de3ff-116b-4f7f-8749-c10bf42344f2" xmi:uuid="c87de3ff-116b-4f7f-8749-c10bf42344f2" body="Maximumwaarde exclusief (&lt;) is de bovengrens van het waardebereik voor een attribuutsoort of data element getypeerd met een primitief datatype, exclusief die waarde zelf. De maximumwaarde moet van hetzelfde primitieve datatype zijn als het datatype van het modelelement waar het voor geldt.">
							<annotatedElement xmi:idref="Ufd1d1ddb-b979-46d8-b3ee-e0e1894ab61d"/>
						</ownedComment>
					</ownedAttribute>
					<ownedAttribute xmi:type="uml:Property" xmi:id="U0dfce268-6120-4420-ac70-e38ad70c052c" xmi:uuid="0dfce268-6120-4420-ac70-e38ad70c052c" name="Maximumwaarde inclusief" visibility="public">
						<xmi:Extension extender="UModel">
							<attributeExtension DocComment="U71f8df5e-24a3-4b08-8896-6e821f8733ef"/>
						</xmi:Extension>
						<ownedComment xmi:type="uml:Comment" xmi:id="U71f8df5e-24a3-4b08-8896-6e821f8733ef" xmi:uuid="71f8df5e-24a3-4b08-8896-6e821f8733ef" body="Maximumwaarde inclusief (&lt;=) is de bovengrens van het waardebereik voor een attribuutsoort of data element getypeerd met een primitief datatype, inclusief die waarde zelf. De maximumwaarde moet van hetzelfde primitieve datatype zijn als het datatype van het modelelement waar het voor geldt.">
							<annotatedElement xmi:idref="U0dfce268-6120-4420-ac70-e38ad70c052c"/>
						</ownedComment>
					</ownedAttribute>
					<ownedAttribute xmi:type="uml:Property" xmi:id="U15a5323a-2f2f-4ef1-9351-dac4da03a03d" xmi:uuid="15a5323a-2f2f-4ef1-9351-dac4da03a03d" name="Minimumwaarde exclusief" visibility="public">
						<xmi:Extension extender="UModel">
							<attributeExtension DocComment="Ue457820b-c1f1-4585-8187-614ec36cadae"/>
						</xmi:Extension>
						<ownedComment xmi:type="uml:Comment" xmi:id="Ue457820b-c1f1-4585-8187-614ec36cadae" xmi:uuid="e457820b-c1f1-4585-8187-614ec36cadae" body="Minimumwaarde exclusief (&gt;) is de ondergrens van het waardebereik voor een attribuutsoort of data element getypeerd met een primitief datatype, exclusief die waarde zelf. De minimumwaarde moet van hetzelfde primitieve datatype zijn als het datatype van het modelelement waar het voor geldt.">
							<annotatedElement xmi:idref="U15a5323a-2f2f-4ef1-9351-dac4da03a03d"/>
						</ownedComment>
					</ownedAttribute>
					<ownedAttribute xmi:type="uml:Property" xmi:id="U81d17275-2ac2-448b-ac1b-a73f52936ce5" xmi:uuid="81d17275-2ac2-448b-ac1b-a73f52936ce5" name="Minimumwaarde inclusief" visibility="public">
						<xmi:Extension extender="UModel">
							<attributeExtension DocComment="U348c4d11-a954-4ae8-850a-9207b518ace8"/>
						</xmi:Extension>
						<ownedComment xmi:type="uml:Comment" xmi:id="U348c4d11-a954-4ae8-850a-9207b518ace8" xmi:uuid="348c4d11-a954-4ae8-850a-9207b518ace8" body="Minimumwaarde inclusief (&gt;=) is de ondergrens van het waardebereik voor een attribuutsoort of data element getypeerd met een primitief datatype, inclusief die waarde zelf. De minimumwaarde moet van hetzelfde primitieve datatype zijn als het datatype van het modelelement waar het voor geldt.">
							<annotatedElement xmi:idref="U81d17275-2ac2-448b-ac1b-a73f52936ce5"/>
						</ownedComment>
					</ownedAttribute>
					<ownedAttribute xmi:type="uml:Property" xmi:id="U391740b6-d6ca-4025-b7af-1173a6374569" xmi:uuid="391740b6-d6ca-4025-b7af-1173a6374569" name="Mogelijk geen waarde" visibility="public" type="U01d95abd-ccbb-400d-8f7c-d9cb4de65445">
