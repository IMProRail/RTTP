					<packagedElement xmi:type="uml:Class" xmi:id="U5f149af9-dba7-41c7-8301-ef6b362ce5fb" xmi:uuid="5f149af9-dba7-41c7-8301-ef6b362ce5fb" name="TrainRunningInformationMessage">
